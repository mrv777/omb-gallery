# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local

# local test scratch (dev sqlite, curl output captures, etc.)
/tmp/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# operational / internal docs — contain VPS IP, SSH commands, deploy details
# that should not leak into a public repo
CLAUDE.md
DEPLOYMENT.md
PHASE2_HANDOFF.md
AGENTS.md
SATFLOW-REWRITE.md
INDEXER-PLAN.md

# server bootstrap + runbooks for the OMB box (bitcoind, ord, Coolify).
# contains generated RPC creds, INTERNAL_POLL_SECRET, host IPs, etc.
/infra/*
# Exception: the upscaler sidecar is deployment-time runtime code that
# needs to track the app's API in lockstep, so it's checked in. It's
# scrubbed of operator-specific details — host runbook lives in the
# local DEPLOYMENT.md.
!/infra/upscaler/

# untracked utility scripts (one-shot tooling, not part of the build)
/scripts/update-descriptions.js
/scripts/test-satflow.mjs
/scripts/test-satflow-e2e.mjs
/scripts/test-listings-e2e.mjs
/scripts/probe-matrica*.mjs

# captured API responses used as ad-hoc fixtures (no secrets, but bulky)
/tests/fixtures/

# Claude Code local state (scheduled task locks, agent worktrees, etc.)
/.claude/
